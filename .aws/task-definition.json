{
  "family": "mk-task",
  "networkMode": "awsvpc",

  "executionRoleArn": "arn:aws:iam::413026844164:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::413026844164:role/ecsTaskExecutionRole",

  "containerDefinitions": [
    {
      "name": "mk-container",
      "image": "<IMAGE_NAME>",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "DB_HOST", "value": "mk-db.c1mc6cksau7z.ap-south-1.rds.amazonaws.com" },
        { "name": "DB_USER", "value": "postgres" },
        { "name": "DB_PASSWORD", "value": "mkdb1234" },
        { "name": "DB_NAME", "value": "mk_db" },
        { "name": "DB_PORT", "value": "5432" }
      ]
    }
  ],
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512"
}
