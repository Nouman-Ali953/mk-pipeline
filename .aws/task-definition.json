{
  "family": "mk-task",
  "networkMode": "awsvpc",

  "executionRoleArn": "arn:aws:iam::413026844164:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::413026844164:role/ecsTaskExecutionRole",

  "containerDefinitions": [
    {
      "name": "mk-container",
      "image": "<IMAGE_NAME>",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ]
    }
  ],
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512"
}
